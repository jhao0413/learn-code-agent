# API Key (required)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxx

# Model ID (required)
MODEL_ID=claude-sonnet-4-6

# Base URL (optional, for Anthropic-compatible providers)
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# =============================================================================
#  Anthropic-compatible providers
#
#  Provider         MODEL_ID              Base URL
#  ---------------  --------------------  -------------------
#  Anthropic        claude-sonnet-4-6     (default)
#  MiniMax          MiniMax-M2.5          see below
#  GLM (Zhipu)      glm-5                 see below
#  Kimi (Moonshot)  kimi-k2.5             see below
#  DeepSeek         deepseek-chat (V3.2)  see below
# =============================================================================

# ---- International ----
# MiniMax          ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
# GLM (Zhipu)      ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# Kimi (Moonshot)  ANTHROPIC_BASE_URL=https://api.moonshot.ai/anthropic
# DeepSeek         ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# ---- China mainland ----
# MiniMax          ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# GLM (Zhipu)      ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
# Kimi (Moonshot)  ANTHROPIC_BASE_URL=https://api.moonshot.cn/anthropic
# DeepSeek (no regional split, same endpoint globally)
